# VAPID Keys dla Web Push Notifications
# Wygeneruj przez: npx web-push generate-vapid-keys
# UWAGA: nigdy nie commituj prawdziwych kluczy - to są placeholdery
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@example.com

# Klucz szyfrowania haseł dla kont email (min. 32 znaki)
# Wygeneruj przez: openssl rand -base64 32
MAIL_ENCRYPTION_SECRET=your-super-secret-encryption-key-min-32-chars

# Domyślne SMTP dla wysyłania maili z kont wewnętrznych do odbiorców zewnętrznych
# Opcjonalne - jeśli nie skonfigurowane, maile zewnętrzne nie będą wysyłane
#
# Przykłady konfiguracji dla różnych dostawców:
#
# === Gmail ===
# DEFAULT_SMTP_HOST=smtp.gmail.com
# DEFAULT_SMTP_PORT=465
# DEFAULT_SMTP_USER=twoj-email@gmail.com
# DEFAULT_SMTP_PASS=haslo-aplikacji (wygeneruj w ustawieniach Google)
#
# === Outlook / Office 365 ===
# DEFAULT_SMTP_HOST=smtp.office365.com
# DEFAULT_SMTP_PORT=587
# DEFAULT_SMTP_USER=twoj-email@outlook.com
# DEFAULT_SMTP_PASS=twoje-haslo
#
# === Yahoo ===
# DEFAULT_SMTP_HOST=smtp.mail.yahoo.com
# DEFAULT_SMTP_PORT=465
# DEFAULT_SMTP_USER=twoj-email@yahoo.com
# DEFAULT_SMTP_PASS=haslo-aplikacji
#
# === OVH ===
# DEFAULT_SMTP_HOST=ssl0.ovh.net
# DEFAULT_SMTP_PORT=465
# DEFAULT_SMTP_USER=twoj-email@twoja-domena.pl
# DEFAULT_SMTP_PASS=twoje-haslo
#
# === nazwa.pl ===
# DEFAULT_SMTP_HOST=mail.nazwa.pl
# DEFAULT_SMTP_PORT=465
# DEFAULT_SMTP_USER=twoj-email@twoja-domena.pl
# DEFAULT_SMTP_PASS=twoje-haslo
#
# === home.pl ===
# DEFAULT_SMTP_HOST=smtp.home.pl
# DEFAULT_SMTP_PORT=465
# DEFAULT_SMTP_USER=twoj-email@twoja-domena.pl
# DEFAULT_SMTP_PASS=twoje-haslo
#
# === Własny serwer (np. Postfix) ===
# DEFAULT_SMTP_HOST=mail.twoja-domena.pl
# DEFAULT_SMTP_PORT=465
# DEFAULT_SMTP_USER=twoj-email@twoja-domena.pl
# DEFAULT_SMTP_PASS=twoje-haslo
#
# Twoja konfiguracja:
DEFAULT_SMTP_HOST=
DEFAULT_SMTP_PORT=465
DEFAULT_SMTP_USER=
DEFAULT_SMTP_PASS=
DEFAULT_SMTP_FROM=Church Manager <email@domena.pl>

# === SMSAPI.pl (moduł SMS Kampanie) ===
# Personal Access Token (Bearer) — wygeneruj w panelu SMSAPI:
#   https://ssl.smsapi.pl/react/oauth/manage
SMSAPI_TOKEN=
# Domyślny nadawca SMS (zarejestrowany w SMSAPI, max 11 znaków alfanumerycznych).
SMSAPI_DEFAULT_SENDER=
# URL bramki (default https://api.smsapi.pl). Można nadpisać dla sandbox/testów.
SMSAPI_API_URL=https://api.smsapi.pl
# Sekretny token do walidacji webhooka MO (incoming SMS).
# Webhook URL: https://<project>.supabase.co/functions/v1/sms-incoming-webhook?secret=<TEN_KLUCZ>
SMSAPI_WEBHOOK_SECRET=
