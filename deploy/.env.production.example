# Avenit — zmienne środowiskowe produkcji (VPS). Skopiuj do .env i uzupełnij.
# NIE commituj pliku .env.

# ── Domena i TLS ─────────────────────────────────────────────────────
APP_DOMAIN=avenit.pl
ACME_EMAIL=admin@avenit.pl
# TLS jest on-demand (HTTP-01) — nie wymaga wtyczki DNS ani tokenu.
# Wymóg: rekord DNS wildcard  *.avenit.pl  A → IP VPS (u dowolnego providera).

# ── Baza danych ──────────────────────────────────────────────────────
POSTGRES_USER=avenit
POSTGRES_PASSWORD=ZMIEN_MNIE_dlugie_haslo

# ── Sekrety aplikacji ────────────────────────────────────────────────
# openssl rand -base64 48
JWT_SECRET=ZMIEN_MNIE_losowy_sekret
# openssl rand -base64 32  (szyfrowanie haseł SMTP/IMAP modułu Mail)
MAIL_ENCRYPTION_SECRET=

# ── E-mail ───────────────────────────────────────────────────────────
SENDGRID_API_KEY=
MAILING_FROM_EMAIL=noreply@avenit.pl
MAILING_FROM_NAME=Avenit
# Resend — używany przez windykację (process-dunning)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@avenit.pl

# ── SMS (SMSAPI.pl) ──────────────────────────────────────────────────
SMSAPI_TOKEN=
SMSAPI_DEFAULT_SENDER=
SMSAPI_WEBHOOK_SECRET=

# ── Push ─────────────────────────────────────────────────────────────
EXPO_ACCESS_TOKEN=
# npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:kontakt@avenit.pl

# ── Płatności Przelewy24 (opcjonalne) ────────────────────────────────
P24_MERCHANT_ID=
P24_POS_ID=
P24_CRC=
P24_API_KEY=
P24_SANDBOX=true

# ── Backup offsite (opcjonalne, rclone) ──────────────────────────────
# Nazwa remote rclone + ścieżka; puste = tylko backup lokalny.
BACKUP_RCLONE_REMOTE=
