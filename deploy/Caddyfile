# Caddy — reverse proxy + TLS on-demand (HTTP-01) + serwowanie statycznych SPA.
# Działa z dowolnym DNS (lh.pl, Hostinger itd.) — bez wtyczki DNS. Wymaga
# jedynie, by hosty rozwiązywały się na to IP (rekord wildcard *.{$APP_DOMAIN}).
#
# JEDEN blok dla domeny głównej + wszystkich subdomen, z on_demand TLS. Dzięki
# temu każdy host (admin/api/domena/tenanci) używa tej samej, deterministycznej
# ścieżki wystawiania certów on-demand (gate: endpoint ask). Routing per host
# przez matchery @admin/@apihost. Wcześniejsze nazwane bloki dostawały politykę
# zarządzaną (proaktywną), która cicho zawodziła przy starcie.

{
	email {$ACME_EMAIL}
	on_demand_tls {
		ask http://api:3001/api/internal/tls-check
	}
}

{$APP_DOMAIN}, *.{$APP_DOMAIN} {
	tls {
		on_demand
	}

	# Panel administracyjny
	@admin host admin.{$APP_DOMAIN}
	handle @admin {
		handle /api/* {
			reverse_proxy api:3001
		}
		handle {
			root * /srv/admin
			try_files {path} /index.html
			file_server
		}
	}

	# API dla aplikacji mobilnej (cały host proxowany do backendu)
	@apihost host api.{$APP_DOMAIN}
	handle @apihost {
		reverse_proxy api:3001
	}

	# Samowyrejestrowujący SW dla avenit.pl i app.avenit.pl (kasuje stary PWA,
	# który cache'ował apkę, gdy te hosty serwowały wcześniej aplikację).
	@killsw {
		host {$APP_DOMAIN} app.{$APP_DOMAIN}
		path /sw.js /sw-push.js
	}
	handle @killsw {
		root * /srv/static
		rewrite * /sw.js
		header Content-Type application/javascript
		header Cache-Control "no-cache, no-store, must-revalidate"
		file_server
	}

	# Domena główna: strona www (landing) + API formularza zgłoszeniowego
	@root host {$APP_DOMAIN}
	handle @root {
		handle /api/* {
			reverse_proxy api:3001
		}
		handle {
			root * /srv/static/landing
			try_files {path} /index.html
			file_server
		}
	}

	# app.domena: strona logowania globalnego (email+hasło → tenant w tle)
	@app host app.{$APP_DOMAIN}
	handle @app {
		handle /api/* {
			reverse_proxy api:3001
		}
		handle {
			root * /srv/static/entry
			try_files {path} /index.html
			file_server
		}
	}

	# Tenanci (subdomena kościoła) → aplikacja web
	handle /api/* {
		reverse_proxy api:3001
	}
	handle /storage/* {
		reverse_proxy api:3001
	}
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}
