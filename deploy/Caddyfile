# Caddy — reverse proxy + TLS (on-demand, HTTP-01) + serwowanie statycznych SPA.
# Działa z dowolnym DNS (lh.pl, Hostinger itd.) — bez wtyczki DNS. Wymaga
# jedynie, by hosty rozwiązywały się na to IP (rekord wildcard *.{$APP_DOMAIN}).
#
# Certyfikaty wystawiane per-host przy pierwszym wejściu; endpoint `ask` w API
# dopuszcza tylko znane subdomeny (admin/api/domena/tenanci).

{
	email {$ACME_EMAIL}
	on_demand_tls {
		ask http://api:3001/api/internal/tls-check
	}
}

# ── Panel administracyjny: admin.domena ──────────────────────────────
# on_demand na wszystkich blokach — cert wystawiany synchronicznie przy
# pierwszym handshake (gate: endpoint ask). Deterministyczne, bez problemów
# z timingiem zarządzanych certów przy starcie Caddy.
admin.{$APP_DOMAIN} {
	tls {
		on_demand
	}
	handle /api/* {
		reverse_proxy api:3001
	}
	handle {
		root * /srv/admin
		try_files {path} /index.html
		file_server
	}
}

# ── API dla aplikacji mobilnej: api.domena ───────────────────────────
api.{$APP_DOMAIN} {
	tls {
		on_demand
	}
	reverse_proxy api:3001
}

# ── Domena główna ────────────────────────────────────────────────────
{$APP_DOMAIN} {
	tls {
		on_demand
	}
	handle /api/* {
		reverse_proxy api:3001
	}
	handle /storage/* {
		reverse_proxy api:3001
	}
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}

# ── Tenanci: *.domena (certyfikat on-demand per subdomena kościoła) ───
*.{$APP_DOMAIN} {
	tls {
		on_demand
	}
	handle /api/realtime {
		reverse_proxy api:3001
	}
	handle /api/* {
		reverse_proxy api:3001
	}
	handle /storage/* {
		reverse_proxy api:3001
	}
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}
