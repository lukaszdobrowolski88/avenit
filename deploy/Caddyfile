# Caddy — reverse proxy + TLS + serwowanie statycznych SPA.
# {$APP_DOMAIN} pochodzi z env. Wildcard TLS przez DNS-01 (Cloudflare).

{
	email {$ACME_EMAIL}
}

# ── Panel administracyjny: admin.domena.pl ───────────────────────────
admin.{$APP_DOMAIN} {
	tls {
		dns cloudflare {$CLOUDFLARE_API_TOKEN}
	}
	# /api → backend
	handle /api/* {
		reverse_proxy api:3001
	}
	# SPA panelu
	handle {
		root * /srv/admin
		try_files {path} /index.html
		file_server
	}
}

# ── API dla aplikacji mobilnej: api.domena.pl ────────────────────────
api.{$APP_DOMAIN} {
	tls {
		dns cloudflare {$CLOUDFLARE_API_TOKEN}
	}
	reverse_proxy api:3001
}

# ── Tenanci: *.domena.pl (każdy kościół na swojej subdomenie) ─────────
*.{$APP_DOMAIN} {
	tls {
		dns cloudflare {$CLOUDFLARE_API_TOKEN}
	}

	# API tenanta (tenant rozpoznawany po nagłówku Host przez backend)
	handle /api/* {
		reverse_proxy api:3001
	}

	# Realtime WebSocket
	handle /api/realtime {
		reverse_proxy api:3001
	}

	# Publiczne pliki storage: /storage/<bucket>/<path>
	# Backend rozpoznaje tenanta po Host i mapuje na katalog na dysku.
	handle /storage/* {
		reverse_proxy api:3001
	}

	# Aplikacja web (SPA)
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}

# ── Domena główna (landing / przekierowanie) ─────────────────────────
{$APP_DOMAIN} {
	tls {
		dns cloudflare {$CLOUDFLARE_API_TOKEN}
	}
	handle /api/* {
		reverse_proxy api:3001
	}
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}
