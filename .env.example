# =====================================================
# Avenit - Zmienne środowiskowe
# =====================================================
# Skopiuj ten plik jako .env i wypełnij wartości

# ===================
# SUPABASE
# ===================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Dla Edge Functions (Supabase Secrets)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===================
# PRZELEWY24
# ===================
# Konto testowe (sandbox): https://sandbox.przelewy24.pl
# Konto produkcyjne: https://secure.przelewy24.pl

P24_MERCHANT_ID=your-merchant-id
P24_POS_ID=your-pos-id-or-same-as-merchant
P24_CRC=your-crc-key
P24_API_KEY=your-api-key
P24_SANDBOX=true

# ===================
# APLIKACJA
# ===================
VITE_APP_URL=https://app.avenit.pl
VITE_LANDING_URL=https://avenit.pl

# Nazwa aplikacji wyświetlana w UI
VITE_APP_NAME=Avenit

# ===================
# EMAIL (Resend)
# ===================
# RESEND_API_KEY=re_your-api-key
# RESEND_FROM_EMAIL=noreply@avenit.pl

# ===================
# OPCJONALNE
# ===================
# Tryb developerski
# VITE_DEV_MODE=true

# Logowanie debugowe
# VITE_DEBUG=true
